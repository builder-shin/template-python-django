# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=django-test
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_CONN_MAX_AGE=60

# Dev Database (for local development convenience)
DEV_DATABASE_USERNAME=postgres

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENV=development

# Auth Service
AUTH_SERVICE_URL=http://localhost:3001
AUTH_SESSION_CACHE_TTL=300
AUTH_REQUEST_TIMEOUT=5

# Auth DB (for FDW - Foreign Data Wrapper cross-database access)
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_dev
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Application
FRONTEND_URL=http://localhost:3000
FALLBACK_APPLICATION_NOTIFICATION_EMAILS=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# IP Blocklist (comma-separated)
BLOCKED_IPS=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Template

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-northeast-2

# Server
PORT=4000
GUNICORN_WORKERS=2
